{
  "name": "pause",
  "productName": "Pause",
  "version": "1.0.0",
  "description": "Pause - a browser with built-in AI chat",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node esbuild.renderer.mjs",
    "start": "tsc && node esbuild.renderer.mjs && electron .",
    "dev": "tsc && node esbuild.renderer.mjs && electron . --enable-logging",
    "package": "tsc && node esbuild.renderer.mjs && electron-builder --mac"
  },
  "build": {
    "appId": "com.pause.browser",
    "productName": "Pause",
    "afterPack": "./build/afterPack.js",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "This app needs access to the camera for websites that request it.",
        "NSMicrophoneUsageDescription": "This app needs access to the microphone for websites that request it.",
        "NSScreenCaptureUsageDescription": "This app needs screen recording access for websites that request screen sharing."
      },
      "protocols": [
        {
          "name": "HTTP",
          "schemes": [
            "http"
          ]
        },
        {
          "name": "HTTPS",
          "schemes": [
            "https"
          ]
        }
      ]
    },
    "files": [
      "dist/**/*",
      "ui/**/*"
    ],
    "extraResources": [
      {
        "from": "icon/icon_dark.icns",
        "to": "icon_dark.icns"
      },
      {
        "from": "icon/icon_light.icns",
        "to": "icon_light.icns"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "ai": "^6.0.116",
    "imapflow": "^1.2.16",
    "katex": "^0.16.38",
    "mailparser": "^3.9.6",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "sql.js": "^1.14.1",
    "uuid": "^13.0.0"
  }
}
